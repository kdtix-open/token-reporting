{
  "name": "token-reporting",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "build:projectit": "TOKEN_REPORTING_BASE_PATH=/tools/token-reporting npm run build",
    "preview": "vite preview",
    "serve:production": "tsx scripts/serve-production.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint .",
    "report:copilot": "tsx scripts/fetch-github-copilot.ts",
    "report:cursor": "tsx scripts/fetch-cursor.ts",
    "report:claude": "tsx scripts/fetch-claude.ts",
    "report:codex": "tsx scripts/fetch-codex.ts",
    "report:claude-code": "tsx scripts/fetch-claude-code.ts",
    "report:local-sessions": "tsx scripts/analyze-local-sessions.ts",
    "report:huggingface-candidates": "tsx scripts/refresh-huggingface-candidates.ts",
    "report:all": "tsx scripts/fetch-all.ts",
    "report:historical": "tsx scripts/fetch-all.ts --historical",
    "report:seed-from-git-history": "tsx scripts/seed-history-from-git.ts",
    "integration:stub": "tsx scripts/serve-integration-stub.ts",
    "integration:api": "tsx scripts/serve-integration-api.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "jsdom": "^27.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.11",
    "vitest": "^4.0.3"
  }
}
